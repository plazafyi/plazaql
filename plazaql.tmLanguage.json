{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "PlazaQL",
  "scopeName": "source.plazaql",
  "fileTypes": ["pql"],
  "patterns": [
    { "include": "#comments" },
    { "include": "#settings" },
    { "include": "#directives" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#atoms" },
    { "include": "#constants" },
    { "include": "#tag-access" },
    { "include": "#attribute-access" },
    { "include": "#variables" },
    { "include": "#output-assignment" },
    { "include": "#element-types" },
    { "include": "#functions" },
    { "include": "#builtin-functions" },
    { "include": "#constructors" },
    { "include": "#methods" },
    { "include": "#keywords" },
    { "include": "#operators" },
    { "include": "#punctuation" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.plazaql",
          "match": "//.*$"
        },
        {
          "name": "comment.block.plazaql",
          "begin": "/\\*",
          "end": "\\*/",
          "captures": {
            "0": { "name": "punctuation.definition.comment.plazaql" }
          }
        }
      ]
    },
    "settings": {
      "patterns": [
        {
          "name": "meta.settings.plazaql",
          "begin": "^\\s*\\[",
          "end": "\\]",
          "beginCaptures": {
            "0": { "name": "punctuation.definition.settings.begin.plazaql" }
          },
          "endCaptures": {
            "0": { "name": "punctuation.definition.settings.end.plazaql" }
          },
          "patterns": [
            {
              "name": "variable.parameter.setting.plazaql",
              "match": "\\b(timeout|dataset|format|maxsize)\\b"
            },
            { "include": "#strings" },
            { "include": "#numbers" },
            { "include": "#operators" },
            { "include": "#punctuation" }
          ]
        }
      ]
    },
    "directives": {
      "patterns": [
        {
          "match": "(#)(within|around|intersects|contains|crosses|touches|not_within|not_intersects|not_contains|buffer|simplify|centroid|precision|fields|include|sort|limit|offset|count|ids|tags|skel|elevation|distance|area|length|expand|h3|filter|bbox|member_of|has_member|geom|sum|min|max|avg|group_by)\\s*(?=\\()",
          "captures": {
            "1": { "name": "keyword.control.directive.plazaql" },
            "2": { "name": "entity.name.function.directive.plazaql" }
          }
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.plazaql",
          "begin": "\"",
          "end": "\"",
          "beginCaptures": {
            "0": { "name": "punctuation.definition.string.begin.plazaql" }
          },
          "endCaptures": {
            "0": { "name": "punctuation.definition.string.end.plazaql" }
          },
          "patterns": [
            {
              "name": "constant.character.escape.plazaql",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.float.plazaql",
          "match": "-?\\b\\d+\\.\\d+\\b"
        },
        {
          "name": "constant.numeric.integer.plazaql",
          "match": "-?\\b\\d+\\b"
        }
      ]
    },
    "atoms": {
      "patterns": [
        {
          "name": "constant.language.atom.plazaql",
          "match": ":[a-zA-Z_][a-zA-Z0-9_]*"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.boolean.plazaql",
          "match": "\\b(true|false)\\b"
        }
      ]
    },
    "tag-access": {
      "patterns": [
        {
          "match": "(t)(\\[)(\"[^\"]*\")(\\])",
          "captures": {
            "1": { "name": "variable.language.tag.plazaql" },
            "2": { "name": "punctuation.bracket.open.plazaql" },
            "3": { "name": "string.quoted.double.plazaql" },
            "4": { "name": "punctuation.bracket.close.plazaql" }
          }
        }
      ]
    },
    "attribute-access": {
      "patterns": [
        {
          "match": "(\\$[a-zA-Z_][a-zA-Z0-9_]*)(\\[)([a-zA-Z_][a-zA-Z0-9_:]*)(\\])",
          "captures": {
            "1": { "name": "variable.other.plazaql" },
            "2": { "name": "punctuation.bracket.open.plazaql" },
            "3": { "name": "entity.name.tag.attribute.plazaql" },
            "4": { "name": "punctuation.bracket.close.plazaql" }
          }
        }
      ]
    },
    "variables": {
      "patterns": [
        {
          "name": "variable.other.plazaql",
          "match": "\\$[a-zA-Z_][a-zA-Z0-9_]*"
        }
      ]
    },
    "output-assignment": {
      "patterns": [
        {
          "match": "(\\$\\$)(?:\\s*\\.\\s*([a-zA-Z_][a-zA-Z0-9_]*))?\\s*=",
          "captures": {
            "1": { "name": "variable.other.output.plazaql" },
            "2": { "name": "variable.other.output.plazaql" }
          }
        },
        {
          "match": "(\\$\\$)\\.([a-zA-Z_][a-zA-Z0-9_]*)(?!\\s*=)",
          "captures": {
            "1": { "name": "variable.other.output.plazaql" },
            "2": { "name": "variable.other.output.plazaql" }
          }
        }
      ]
    },
    "element-types": {
      "patterns": [
        {
          "name": "keyword.other.element-type.plazaql",
          "match": "\\b(node|way|relation|nwr)\\b"
        }
      ]
    },
    "functions": {
      "patterns": [
        {
          "name": "entity.name.function.plazaql",
          "match": "\\b(search|area|route|isochrone|geocode|reverse_geocode|autocomplete|text_search|matrix|map_match|optimize|ev_route|elevation|elevation_profile|nearest)\\s*(?=\\()"
        }
      ]
    },
    "builtin-functions": {
      "patterns": [
        {
          "name": "support.function.builtin.plazaql",
          "match": "\\b(id|type|lat|lon|length|area|is_closed|number|is_number|starts_with|ends_with|str_contains|size)\\s*(?=\\()"
        }
      ]
    },
    "constructors": {
      "patterns": [
        {
          "name": "entity.name.function.constructor.plazaql",
          "match": "\\b(point|linestring|polygon|bbox|circle)\\s*(?=\\()"
        }
      ]
    },
    "methods": {
      "patterns": [
        {
          "match": "\\.\\s*(within|around|intersects|contains|crosses|touches|not_within|not_intersects|not_contains|buffer|simplify|centroid|precision|fields|include|sort|limit|offset|count|ids|tags|skel|elevation|distance|area|length|expand|h3|filter|bbox|member_of|has_member|first|last|index|geom|sum|min|max|avg|group_by)\\s*(?=\\(|;|$)",
          "captures": {
            "1": { "name": "entity.name.function.method.plazaql" }
          }
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.plazaql",
          "match": "\\b(search|area)\\b(?!\\s*[.(])"
        },
        {
          "name": "keyword.other.modifier.plazaql",
          "match": "~i(?=\")"
        },
        {
          "name": "keyword.other.modifier.plazaql",
          "match": "~(?=\")"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.logical.plazaql",
          "match": "&&|\\|\\|"
        },
        {
          "name": "keyword.operator.comparison.plazaql",
          "match": ">=|<=|!=|==|>|<"
        },
        {
          "name": "keyword.operator.assignment.plazaql",
          "match": "="
        },
        {
          "name": "keyword.operator.set.plazaql",
          "match": "&"
        },
        {
          "name": "keyword.operator.arithmetic.plazaql",
          "match": "[+\\-*\\/]"
        },
        {
          "name": "keyword.operator.negation.plazaql",
          "match": "!"
        },
        {
          "name": "keyword.operator.plazaql",
          "match": "[~*:]"
        }
      ]
    },
    "punctuation": {
      "patterns": [
        {
          "name": "punctuation.parenthesis.open.plazaql",
          "match": "\\("
        },
        {
          "name": "punctuation.parenthesis.close.plazaql",
          "match": "\\)"
        },
        {
          "name": "punctuation.bracket.open.plazaql",
          "match": "\\["
        },
        {
          "name": "punctuation.bracket.close.plazaql",
          "match": "\\]"
        },
        {
          "name": "punctuation.separator.comma.plazaql",
          "match": ","
        },
        {
          "name": "punctuation.terminator.statement.plazaql",
          "match": ";"
        },
        {
          "name": "punctuation.accessor.dot.plazaql",
          "match": "\\."
        }
      ]
    }
  }
}
